{
  "name": "financial-tracker",
  "version": "0.0.2",
  "scripts": {
    "ng": "ng",
    "start": "npm run newPatch && ng serve",
    "dev": "npm run newPatch && ng serve",
    "build": "npm run newPatch && ng build",
    "watch": "npm run newPatch && ng build --watch --configuration development",
    "test": "npm run newPatch && ng test",
    "newPatch": "npm --no-git-tag-version version patch",
    "newMinor": "npm --no-git-tag-version version minor",
    "newMajor": "npm --no-git-tag-version version major",
    "commit": "npm run newPatch && aic2 -t conventional",
    "commit-all": "npm run newPatch && aic2 -a -t conventional",
    "push": "npm run newPatch && aic2 -t conventional && git push",
    "push-all": "npm run newPatch && aic2 -a -t conventional && git push"
  },
  "private": true,
  "dependencies": {},
  "devDependencies": {}
}
