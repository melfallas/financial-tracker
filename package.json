{
  "name": "financial-tracker",
  "version": "0.0.6",
  "scripts": {
    "ng": "ng",
    "start": "npm run new-patch && ng serve",
    "dev": "npm run new-patch && ng serve",
    "build": "npm run new-patch && ng build",
    "watch": "npm run new-patch && ng build --watch --configuration development",
    "test": "npm run new-patch && ng test",
    "release": "commit-and-tag-version",
    "new-patch": "npm --no-git-tag-version version patch",
    "new-minor": "npm --no-git-tag-version version minor",
    "new-major": "npm --no-git-tag-version version major",
    "commit": "npm run new-patch && aic2 -t conventional",
    "commit-all": "npm run new-patch && aic2 -a -t conventional",
    "push": "npm run new-patch && aic2 -t conventional && git push",
    "push-all": "npm run new-patch && aic2 -a -t conventional && git push"
  },
  "private": true,
  "commit-and-tag-version": {
    "skip": {
      "tag": true
    }
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.6.1"
  }
}
